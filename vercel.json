{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/v1/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/product/([^/]+)",
      "dest": "/frontend/product/[id]?nxtPid=$1"
    },
    {
      "src": "/stories/([^/]+)",
      "dest": "/frontend/stories/[id]?nxtPid=$1"
    },
    {
      "src": "/campaign/([^/]+)",
      "dest": "/frontend/campaign/[id]?nxtPid=$1"
    },
    {
      "src": "/admin/feedback/([^/]+)",
      "dest": "/frontend/admin/feedback/[ticketNumber]?nxtPticketNumber=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
