# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Chat demo mode (bypasses OpenAI + DB for demo responses)
CHAT_DEMO_MODE=false

# Chat review notifications
CHAT_REVIEW_NOTIFICATION_PROVIDER=slack
CHAT_REVIEW_WEBHOOK_URL=

# Chat job scheduler
CHAT_JOB_SCHEDULER_ENABLED=false
CHAT_JOB_DECAY_INTERVAL_MINUTES=1440
CHAT_JOB_SUMMARY_INTERVAL_MINUTES=360

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=muse_shopping_dev
DB_USER=muse_admin
DB_PASSWORD=your_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars_random_string_here
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_random_string_here
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Logging
LOG_LEVEL=debug

# Gmail API Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/email/callback

# Encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# Meta/Facebook/Instagram
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:3000/api/v1/social/meta/callback

# App URLs
APP_URL=https://yourdomain.com
# For data deletion callback: https://yourdomain.com/api/v1/data-deletion-callback

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-2024-08-06
OPENAI_INTENT_MODEL=gpt-4o-mini-2024-07-18
OPENAI_API_BASE=https://api.openai.com/v1

# Chat Export Storage
CHAT_EXPORT_STORAGE=local
CHAT_EXPORT_BUCKET=your_bucket_name_here
CHAT_EXPORT_PREFIX=chat-exports
CHAT_EXPORT_DIR=./exports
CHAT_EXPORT_RETENTION_DAYS=30
CHAT_EXPORT_PUBLIC_BASE=
AWS_REGION=us-east-1
CHAT_EXPORT_URL_TTL_SECONDS=3600
CHAT_MODEL_TIMEOUT_MS=20000
CHAT_EMBEDDINGS_ENABLED=false
CHAT_EMBEDDINGS_MODEL=text-embedding-3-small

# Stripe Payment Processing
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Webhook secret from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Set to true for live payments (production only)
STRIPE_LIVE_MODE=false

# Frontend public variables (set in frontend/.env.local)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
NEXT_PUBLIC_APPLE_CLIENT_ID=com.muse.shopping

# Feature flags for launch validation
ENABLE_STRIPE_PAYMENTS=true
ENABLE_TRANSACTIONAL_EMAIL=true
ENABLE_GOOGLE_AUTH=true
ENABLE_APPLE_AUTH=true
ENABLE_META_AUTH=false

# Cart Requirement Adapters (env-driven policy configuration)
# These values are intentionally conservative scaffolding defaults
CART_MAX_QUANTITY_PER_ITEM=99
CART_MAX_TOTAL_QUANTITY=500
CART_MAX_DISTINCT_ITEMS=100
CART_ALLOWED_CURRENCIES=USD
CART_WARN_AT_PERCENT=85
# Comma-separated store IDs (optional): CART_ALLOWED_STORE_IDS=1,2,3
CART_ALLOWED_STORE_IDS=
CART_BLOCKED_STORE_IDS=
# Comma-separated product types (optional): CART_ALLOWED_PRODUCT_TYPES=APPAREL,BEAUTY
CART_ALLOWED_PRODUCT_TYPES=
CART_BLOCKED_PRODUCT_TYPES=

# Checkout Requirement Adapters
CHECKOUT_MAX_STORES=20
CHECKOUT_REQUIRE_ITEMS_IN_STOCK=true
CHECKOUT_MAX_SUBTOTAL_CENTS=1000000
CHECKOUT_ALLOWED_STORE_IDS=
CHECKOUT_BLOCKED_STORE_IDS=
CHECKOUT_ALLOWED_PRODUCT_TYPES=
CHECKOUT_BLOCKED_PRODUCT_TYPES=

# Monitoring & Alerts
# Slack webhook for real-time alerts (critical errors, payment failures, etc.)
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
# Optional: Sentry for comprehensive error tracking
SENTRY_DSN=

# Email Service (SMTP Configuration)
# For password resets, welcome emails, and notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
BASE_URL=http://localhost:3001
EMAIL_FROM=Muse <noreply@muse.shopping>
EMAIL_FROM_NOREPLY=Muse <noreply@muse.shopping>
EMAIL_FROM_TEAM=Muse Team <team@muse.shopping>
EMAIL_FROM_MARKETING=Muse <hello@muse.shopping>
EMAIL_FROM_SUPPORT=support@muse.shopping
EMAIL_FEEDBACK=feedback@muse.shopping
EMAIL_HELP=help@muse.shopping
